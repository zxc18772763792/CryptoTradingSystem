# API Keys (填入你的API密钥)
BINANCE_API_KEY=your_binance_api_key
BINANCE_API_SECRET=your_binance_api_secret

OKX_API_KEY=your_okx_api_key
OKX_API_SECRET=your_okx_api_secret
OKX_PASSPHRASE=your_okx_passphrase

GATE_API_KEY=your_gate_api_key
GATE_API_SECRET=your_gate_api_secret

BYBIT_API_KEY=your_bybit_api_key
BYBIT_API_SECRET=your_bybit_api_secret

# News/LLM (optional)
ZHIPU_API_KEY=
ZHIPU_MODEL=glm-5
ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4
NEWSAPI_KEY=
CRYPTOPANIC_TOKEN=
CMC_API_KEY=
NEWS_ENABLE_GDELT=true
NEWS_ENABLE_NEWSAPI=true
NEWS_ENABLE_CRYPTOPANIC=true
NEWS_PULL_INTERVAL_SEC=180
NEWS_PULL_SINCE_MINUTES=180
NEWS_PULL_MAX_RECORDS=120

# Database
DATABASE_URL=sqlite+aiosqlite:///./data/crypto_trading.db
REDIS_URL=redis://localhost:6379/0

# Proxy (可选，用于访问交易所API)
HTTP_PROXY=
HTTPS_PROXY=

# Trading Settings
TRADING_MODE=paper  # paper 或 live
MAX_POSITION_SIZE=0.1  # 最大仓位比例
MAX_DAILY_LOSS=0.02  # 最大日亏损比例
MIN_STRATEGY_ORDER_USD=100  # 策略自动下单最小名义金额（USD）
PAPER_INITIAL_EQUITY=10000  # 模拟盘初始资金（USD）
PAPER_FEE_RATE=0.001  # 模拟盘单边手续费率
PAPER_SLIPPAGE_BPS=2  # 模拟盘单边滑点（bps）
RISK_FREE_RATE=0.02  # 无风险利率

# Data Settings
DATA_STORAGE_PATH=./data/historical
CACHE_PATH=./data/cache
LOG_PATH=./logs

# Web Settings
WEB_HOST=0.0.0.0
WEB_PORT=8000
WEB_SECRET_KEY=your_secret_key_here_change_in_production

# Alert Settings (可选)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
FEISHU_BOT_WEBHOOK_URL=
FEISHU_BOT_SECRET=
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_RECEIVE_ID=
FEISHU_RECEIVE_ID_TYPE=chat_id
EMAIL_SMTP_SERVER=
EMAIL_SMTP_PORT=587
EMAIL_USE_TLS=true
EMAIL_USE_SSL=false
EMAIL_TIMEOUT_SEC=15
EMAIL_REQUIRE_AUTH=true
EMAIL_SENDER=
EMAIL_PASSWORD=
EMAIL_RECEIVER=
